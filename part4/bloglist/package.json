{
  "name": "bloglist-backend",
  "version": "1.0.0",
  "description": "bloglist backend",
  "license": "MIT",
  "author": "hub2jo",
  "main": "index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node index.js",
    "dev": "cross-env NODE_ENV=development nodemon -L index.js",
    "test": "cross-env NODE_ENV=test node --test",
    "build:ui": "rm -rf dist && cd ../notes_frontend && npm run build && cp -r dist ../notes_backend",
    "deploy:full": "npm run build:ui && git add . && git commit -m uibuild && git push"
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "mongoose": "^9.1.5",
    "morgan": "^1.10.1",
    "supertest": "^7.2.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
